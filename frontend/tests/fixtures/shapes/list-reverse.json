{"code":"// Build 1->2->3 then reverse it in place. Leaks on purpose; trace ends at return.\nstruct ListNode {\n    int val;\n    ListNode* next;\n    ListNode(int v) : val(v), next(nullptr) {}\n};\n\nint main() {\n    ListNode* head = new ListNode(1);\n    head->next = new ListNode(2);\n    head->next->next = new ListNode(3);\n\n    ListNode* prev = nullptr;\n    ListNode* curr = head;\n    while (curr) {\n        ListNode* nxt = curr->next;\n        curr->next = prev;\n        prev = curr;\n        curr = nxt;\n    }\n    head = prev;\n    return 0;\n}\n","trace":[{"line":8,"event":"step_line","func_name":"main","stack_to_render":[{"encoded_locals":{},"frame_id":"0xFFF000B60_0","func_name":"main","is_highlighted":true,"is_parent":false,"is_zombie":false,"line":8,"ordered_varnames":[],"parent_frame_id_list":[],"unique_hash":"main_0xFFF000B60_0"}],"heap":{},"globals":{},"ordered_globals":[],"stdout":"","exception_msg":""},{"line":9,"event":"step_line","func_name":"main","stack_to_render":[{"encoded_locals":{},"frame_id":"0xFFF000B20_0","func_name":"main","is_highlighted":true,"is_parent":false,"is_zombie":false,"line":8,"ordered_varnames":[],"parent_frame_id_list":[],"unique_hash":"main_0xFFF000B20_0"}],"heap":{},"globals":{},"ordered_globals":[],"stdout":"","exception_msg":""},{"line":5,"event":"call","func_name":"ListNode::ListNode(int)","stack_to_render":[{"encoded_locals":{"curr":["C_DATA","0xFFF000B48","pointer","<UNINITIALIZED>"],"head":["C_DATA","0xFFF000B50","pointer","<UNINITIALIZED>"],"prev":["C_DATA","0xFFF000B40","pointer","<UNINITIALIZED>"]},"frame_id":"0xFFF000B20_0","func_name":"main","is_highlighted":false,"is_parent":false,"is_zombie":false,"line":9,"ordered_varnames":["head","prev","curr"],"parent_frame_id_list":[],"unique_hash":"main_0xFFF000B20_0"},{"encoded_locals":{},"frame_id":"0xFFF000B20_1","func_name":"ListNode::ListNode(int)","is_highlighted":true,"is_parent":false,"is_zombie":false,"line":5,"ordered_varnames":[],"parent_frame_id_list":[],