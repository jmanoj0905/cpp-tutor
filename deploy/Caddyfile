# Caddy config for the cpp-tutor VM.
# Serves the built frontend and reverse-proxies the API, same origin.
# Caddy obtains + renews a Let's Encrypt cert automatically for this hostname.
cpp-tutor.centralindia.cloudapp.azure.com {
	encode gzip

	handle /api/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle {
		root * /var/www/cpp-tutor
		try_files {path} /index.html
		file_server
	}
}
