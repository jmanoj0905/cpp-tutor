+// pgbovine/cpp-tutor: node-payload recovery helpers.
+
+static const HChar* pg_type_name(TyEnt* e)
+{
+   if (!e) return NULL;
+   switch (e->tag) {
+      case Te_TyBase: return e->Te.TyBase.name;
+      case Te_TyTyDef: return e->Te.TyTyDef.name;
+      case Te_TyStOrUn: return e->Te.TyStOrUn.name;
+      case Te_TyEnum: return e->Te.TyEnum.name;
+      default: return NULL;
+   }
+}
+
+static Bool pg_name_matches(const HChar* actual, const HChar* candidate)
+{
+   SizeT alen, clen;
+   if (!actual || !candidate) return False;
+   if (VG_(strcmp)(actual, candidate) == 0) return True;
+   if (VG_(strncmp)(candidate, "std::", 5) == 0
+       && VG_(strcmp)(actual, candidate + 5) == 0)
+      return True;
+   alen = VG_(strlen)(actual);
+   clen = VG_(strlen)(candidate);
+   if (alen > clen
+       && VG_(strcmp)(actual + alen - clen, candidate) == 0
+       && actual[alen - clen - 1] == ':'
+       && alen >= clen + 2
+       && actual[alen - clen - 2] == ':')
+      return True;
+   if (VG_(strncmp)(candidate, "std::", 5) == 0) {
+      candidate += 5;
+      clen -= 5;
+      if (alen > clen
+          && VG_(strcmp)(actual + alen - clen, candidate) == 0
+          && actual[alen - clen - 1] == ':'
+          && alen >= clen + 2
+          && actual[alen - clen - 2] == ':')
+         return True;
+   }
+   return False;
+}
+
+/* Find a named type in the CU table. Linear scan is acceptable: this runs once
+ * per container decode and Valgrind's DWARF walk dominates the cost. */
+static TyEnt* pg_find_type_by_name(const XArray* tyents,
+                                   const HChar* name,
+                                   Bool structs_only)
+{
+   Word i, n = VG_(sizeXA)(tyents);
+   for (i = 0; i < n; i++) {
+      TyEnt* e = (TyEnt*)VG_(indexXA)(tyents, i);
+      if (structs_only && e->tag != Te_TyStOrUn) continue;
+      if (pg_name_matches(pg_type_name(e), name)) {
+         return e;
+      }
+   }
+   return NULL;
 }
 
+static TyEnt* pg_find_struct_by_name(const XArray* tyents, const HChar* name)
+{
+   return pg_find_type_by_name(tyents, name, True);
+}
 
+/* Extract the Nth top-level (depth-0) template argument from a name like
+ * "map<int, int, ...>" -> "int". Writes "" into `out` if no arg exists.
+ * Trims surrounding whitespace. */
+static void pg_template_arg(const HChar* name, Int wanted, HChar* out, SizeT outsz)
+{
+   const HChar* lt = VG_(strchr)(name, '<');
+   Int arg = 0;
+   SizeT i = 0;
+   out[0] = '\0';
+   if (!lt) return;
+   {
+      const HChar* p = lt + 1;
+      Int depth = 0;
+      while (*p && i + 1 < outsz) {
+         if (*p == '<') {
+            if (arg == wanted) out[i++] = *p;
+            depth++;
+         } else if (*p == '>') {
+            if (depth == 0) break;
+            depth--;
+            if (arg == wanted) out[i++] = *p;
+         } else if (*p == ',' && depth == 0) {
+            if (arg == wanted) break;
+            arg++;
+            i = 0;
+         } else if (arg == wanted) {
+            out[i++] = *p;
+         }
+         p++;
+      }
+   }
+   out[i] = '\0';
+   while (i > 0 && out[i - 1] == ' ') { out[--i] = '\0'; }
+   {
+      SizeT s = 0;
+      while (out[s] == ' ') { s++; }
+      if (s > 0) {
+         SizeT j = 0;
+         while (out[s]) { out[j++] = out[s++]; }
+         out[j] = '\0';
+      }
+   }
+}
+
+static void pg_first_template_arg(const HChar* name, HChar* out, SizeT outsz)
+{
+   pg_template_arg(name, 0, out, outsz);
+}
