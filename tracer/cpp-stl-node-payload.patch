+// pgbovine/cpp-tutor: node-based container family table. Each row pairs a
+// container-type-name prefix with (a) the type-erased node base whose pointer
+// the heap-block walker sees, and (b) a printf-style template for constructing
+// the derived per-node struct name from the container's first template arg.
+// When a container's Te_TyStOrUn decode matches a row, we resolve the derived
+// node struct BY NAME and push it as a scoped override so the Te_TyPtr walker
+// substitutes it (and its real DWARF size) for the base — exposing the payload
+// member. This generalizes the original hardcoded list<T> pairing.
+//
+// Only `list` is wired here: its derived name is exactly
+// `_List_node<FIRST_ARG>` and its payload is a plain member. The other
+// node-based families were diagnosed (Task 5 gates) and DO carry recoverable
+// derived nodes + payload members in DWARF, but their derived names are not a
+// simple `<%s>` of the container's first template arg and so are deferred to
+// their own tasks:
+//   * forward_list -> `_Fwd_list_node<int>`, payload `_M_storage`
+//     (an __aligned_membuf `type`, not a plain scalar).
+//   * set/multiset  -> `_Rb_tree_node<int>`, payload `_M_value_field`;
+//     nodes reached via the `_Base_ptr`/`_Link_type` TYPEDEFS (needs the
+//     typedef stripping below).
+//   * map/multimap  -> `_Rb_tree_node<std::pair<K const, V> >`, payload
+//     `_M_value_field`; derived name needs the pair type assembled, not the
+//     container's first arg.
+//   * unordered_*   -> `_Hash_node<T, false>` in namespace std::__detail,
+//     payload `_M_v`; derived name needs the trailing cache-hash-code bool;
+//     nodes reached via the `__node_base` typedef.
+typedef struct {
+   const HChar* container_prefix; // container type-name prefix, e.g. "list<"
+   SizeT        prefix_len;       // strlen(container_prefix)
+   const HChar* base_name;        // type-erased node base, e.g. "_List_node_base"
+   const HChar* derived_fmt;      // derived name template, one %s, e.g. "_List_node<%s>"
+} PgNodeFamily;
+
+static const PgNodeFamily pg_node_families[] = {
+   { "list<", 5, "_List_node_base", "_List_node<%s>" },
+   // forward_list / tree / hash families: gates PASS (see Task 5 report) but
+   // wiring deferred to Tasks 6-8 (see comment above for their derived-name /
+   // payload specifics).
+};
+#define PG_NUM_NODE_FAMILIES \
+   (sizeof(pg_node_families) / sizeof(pg_node_families[0]))
+
+/* If `container_name` matches a node-family row, construct the derived node
+ * type name from its first template arg, resolve it BY NAME, and return the
+ * matching row (via *out_family) plus the resolved derived TyEnt. Returns NULL
+ * if no family matches or the derived type isn't present in this CU's DWARF. */
+static TyEnt* pg_resolve_node_override(const XArray* tyents,
+                                       const HChar* container_name,
+                                       const PgNodeFamily** out_family)
+{
+   SizeT k;
+   for (k = 0; k < PG_NUM_NODE_FAMILIES; k++) {
+      const PgNodeFamily* fam = &pg_node_families[k];
+      if (VG_(strncmp)(container_name, fam->container_prefix,
+                       fam->prefix_len) != 0)
+         continue;
+      {
+         HChar elem[128];
+         pg_first_template_arg(container_name, elem, sizeof(elem));
+         if (elem[0]) {
+            HChar candidate[192];
+            TyEnt* derived;
+            VG_(snprintf)(candidate, sizeof(candidate), fam->derived_fmt, elem);
+            derived = pg_find_struct_by_name(tyents, candidate);
+            if (derived) {
+               if (out_family) *out_family = fam;
+               return derived;
+            }
+         }
+      }
+      // matched the prefix but couldn't resolve a derived type: stop looking
+      // (a container name matches at most one family) and fall through to
+      // today's base-only behavior.
+      break;
+   }
+   return NULL;
+}
