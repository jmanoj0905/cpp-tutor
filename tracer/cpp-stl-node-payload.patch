+// pgbovine/cpp-tutor: scoped override for the Te_TyPtr heap-block decoder.
+// Pushed when entering a node container's own Te_TyStOrUn decode, popped on
+// exit. A stack (not a single global) because nested node containers must not
+// clobber outer active overrides.
+#define PG_NODE_OVERRIDE_MAX 32
+typedef struct {
+   const HChar* base_name;
+   TyEnt* derived;
+   const HChar* storage_field;
+   UWord storage_typeR;
+} PgNodeOverride;
+static PgNodeOverride pg_node_override_stack[PG_NODE_OVERRIDE_MAX];
+static Int pg_node_override_sp = 0;
+
+static void pg_push_node_override(const HChar* base_name,
+                                  TyEnt* derived,
+                                  const HChar* storage_field,
+                                  UWord storage_typeR)
+{
+   if (pg_node_override_sp < PG_NODE_OVERRIDE_MAX) {
+      pg_node_override_stack[pg_node_override_sp].base_name = base_name;
+      pg_node_override_stack[pg_node_override_sp].derived = derived;
+      pg_node_override_stack[pg_node_override_sp].storage_field = storage_field;
+      pg_node_override_stack[pg_node_override_sp].storage_typeR = storage_typeR;
+      pg_node_override_sp++;
+   }
+   // silently drop the override past MAX_DEPTH nesting: falls back to
+   // base-only decode for that deeply-nested case rather than crashing.
+}
+
+static void pg_pop_node_override(void)
+{
+   if (pg_node_override_sp > 0) { pg_node_override_sp--; }
+}
+
+/* Topmost active override whose base_name matches, or NULL. Searches from
+ * the top of the stack down so the innermost enclosing container wins. */
+static PgNodeOverride* pg_active_node_override(const HChar* base_name)
+{
+   Int i;
+   for (i = pg_node_override_sp - 1; i >= 0; i--) {
+      if (VG_(strcmp)(pg_node_override_stack[i].base_name, base_name) == 0) {
+         return &pg_node_override_stack[i];
+      }
+   }
+   return NULL;
+}
+
+static UWord pg_storage_payload_typeR(TyEnt* derived, const HChar* field_name)
+{
+   Int i;
+   for (i = pg_node_override_sp - 1; i >= 0; i--) {
+      PgNodeOverride* ov = &pg_node_override_stack[i];
+      if (ov->derived == derived
+          && ov->storage_field
+          && field_name
+          && VG_(strcmp)(ov->storage_field, field_name) == 0
+          && ov->storage_typeR != (UWord)(-1UL)) {
+         return ov->storage_typeR;
+      }
+   }
+   return (UWord)(-1UL);
+}
+
+/* Resolve through Te_TyTyDef (typedef) and Te_TyQual (const/volatile/restrict)
+ * layers to the underlying type entity. Tree/hash containers reach their nodes
+ * via _Base_ptr / _Link_type / __node_base_ptr TYPEDEFS, so the pointee type
+ * is a Te_TyTyDef (or a qualified typedef), not a direct Te_TyStOrUn — a plain
+ * `pointee->tag == Te_TyStOrUn` check silently misses them. list pointees are
+ * direct struct types, so for list this is a no-op that returns the same
+ * entity. Returns NULL if the chain dead-ends at an unknown type. */
+static TyEnt* pg_strip_typedefs_quals(const XArray* tyents, UWord typeR)
+{
+   TyEnt* e = ML_(TyEnts__index_by_cuOff)(tyents, NULL, typeR);
+   Int guard = 0;
+   while (e && (e->tag == Te_TyTyDef || e->tag == Te_TyQual) && guard++ < 64) {
+      UWord next = (e->tag == Te_TyTyDef) ? e->Te.TyTyDef.typeR
+                                          : e->Te.TyQual.typeR;
+      if (next == (UWord)(-1UL) /* D3_INVALID_CUOFF */) return NULL;
+      e = ML_(TyEnts__index_by_cuOff)(tyents, NULL, next);
+   }
+   return e;
+}
+
+typedef enum {
+   PgNodeFirstArg,
+   PgNodePairArg,
+   PgNodeHashFirstArg,
+   PgNodeHashPairArg
+} PgNodeNameKind;
+
+typedef struct {
+   const HChar* container_prefix; // container type-name prefix, e.g. "list<"
+   SizeT        prefix_len;       // strlen(container_prefix)
+   const HChar* base_name;        // type-erased node base, e.g. "_List_node_base"
+   const HChar* derived_fmt;
+   PgNodeNameKind name_kind;
+   const HChar* storage_field;    // e.g. forward_list _M_storage, else NULL
+} PgNodeFamily;
+
+static const PgNodeFamily pg_node_families[] = {
+   { "forward_list<", 13, "_Fwd_list_node_base",
+     "_Fwd_list_node<%s>", PgNodeFirstArg, "_M_storage" },
+   { "list<", 5, "_List_node_base",
+     "_List_node<%s>", PgNodeFirstArg, NULL },
+   { "set<", 4, "_Rb_tree_node_base",
+     "_Rb_tree_node<%s>", PgNodeFirstArg, NULL },
+   { "multiset<", 9, "_Rb_tree_node_base",
+     "_Rb_tree_node<%s>", PgNodeFirstArg, NULL },
+   { "map<", 4, "_Rb_tree_node_base",
+     "_Rb_tree_node<std::pair<%s const, %s> >", PgNodePairArg, NULL },
+   { "multimap<", 9, "_Rb_tree_node_base",
+     "_Rb_tree_node<std::pair<%s const, %s> >", PgNodePairArg, NULL },
+   { "unordered_set<", 14, "_Hash_node_base",
+     "_Hash_node<%s, false>", PgNodeHashFirstArg, NULL },
+   { "unordered_multiset<", 19, "_Hash_node_base",
+     "_Hash_node<%s, false>", PgNodeHashFirstArg, NULL },
+   { "unordered_map<", 14, "_Hash_node_base",
+     "_Hash_node<std::pair<%s const, %s>, false>", PgNodeHashPairArg, NULL },
+   { "unordered_multimap<", 19, "_Hash_node_base",
+     "_Hash_node<std::pair<%s const, %s>, false>", PgNodeHashPairArg, NULL },
+};
+#define PG_NUM_NODE_FAMILIES \
+   (sizeof(pg_node_families) / sizeof(pg_node_families[0]))
+
+static Bool pg_build_node_name(const PgNodeFamily* fam,
+                               const HChar* container_name,
+                               HChar* out,
+                               SizeT outsz)
+{
+   HChar a0[128];
+   HChar a1[128];
+   pg_template_arg(container_name, 0, a0, sizeof(a0));
+   if (!a0[0]) return False;
+   switch (fam->name_kind) {
+      case PgNodeFirstArg:
+      case PgNodeHashFirstArg:
+         VG_(snprintf)(out, outsz, fam->derived_fmt, a0);
+         return True;
+      case PgNodePairArg:
+      case PgNodeHashPairArg:
+         pg_template_arg(container_name, 1, a1, sizeof(a1));
+         if (!a1[0]) return False;
+         VG_(snprintf)(out, outsz, fam->derived_fmt, a0, a1);
+         return True;
+      default:
+         return False;
+   }
+}
+
+/* If `container_name` matches a node-family row, construct the derived node
+ * type name, resolve it BY NAME, and return the matching row (via *out_family)
+ * plus the resolved derived TyEnt. Returns NULL if no family matches or the
+ * derived type isn't present in this CU's DWARF. */
+static TyEnt* pg_resolve_node_override(const XArray* tyents,
+                                       const HChar* container_name,
+                                       const PgNodeFamily** out_family,
+                                       UWord* out_storage_typeR)
+{
+   SizeT k;
+   const HChar* normalized = container_name;
+   if (out_storage_typeR) *out_storage_typeR = (UWord)(-1UL);
+   if (VG_(strncmp)(normalized, "std::", 5) == 0) normalized += 5;
+   for (k = 0; k < PG_NUM_NODE_FAMILIES; k++) {
+      const PgNodeFamily* fam = &pg_node_families[k];
+      if (VG_(strncmp)(normalized, fam->container_prefix,
+                       fam->prefix_len) != 0)
+         continue;
+      {
+         HChar candidate[256];
+         TyEnt* derived;
+         if (!pg_build_node_name(fam, normalized, candidate, sizeof(candidate)))
+            break;
+         derived = pg_find_struct_by_name(tyents, candidate);
+         if (derived) {
+            if (out_family) *out_family = fam;
+            if (out_storage_typeR && fam->storage_field) {
+               HChar elem[128];
+               TyEnt* payload_type;
+               pg_first_template_arg(normalized, elem, sizeof(elem));
+               payload_type = pg_find_type_by_name(tyents, elem, False);
+               if (payload_type) *out_storage_typeR = payload_type->cuOff;
+            }
+            return derived;
+         }
+      }
+      // matched the prefix but couldn't resolve a derived type: stop looking
+      // (a container name matches at most one family) and fall through to
+      // today's base-only behavior.
+      break;
+   }
+   return NULL;
+}
